# Copie este conteudo para o campo "Environment variables" no Portainer
# ao criar o Stack. Troque os valores antes de deployar.

DB_USER=crm
DB_PASSWORD=SuaSenhaForteAqui123!
ACCESS_TOKEN_SECRET=mude-para-uma-string-aleatoria-de-64-caracteres-12345678901234
REFRESH_TOKEN_SECRET=mude-para-outra-string-aleatoria-diferente-12345678901234567

# Google Drive (uploads do formulario de onboarding)
# ID da pasta raiz do Google Drive que foi compartilhada com o email da Service Account.
# Criar via Drive > nova pasta > compartilhar com email da SA > copiar o ID da URL.
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Obs: o arquivo JSON da Service Account e montado via Docker secret "gdrive_sa"
# em /run/secrets/gdrive_sa (ver docker-compose.yml). Criar o secret com:
#   docker secret create gdrive_sa /caminho/para/service-account.json
# O env GOOGLE_DRIVE_SA_JSON ja esta fixo no compose para esse path.
