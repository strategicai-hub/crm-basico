generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum StageType {
  OPEN
  WON
  LOST
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum OnboardingNiche {
  ACADEMIA
  ESCOLA_CURSOS
  CONSORCIO
  GENERICO
}

enum OnboardingTargetPlan {
  START
  PLENO
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  clients          Client[]
  deals            Deal[]
  tasks            Task[]
  activities       Activity[]
  refreshTokens    RefreshToken[]
  onboardingForms  OnboardingForm[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Client {
  id             String   @id @default(uuid())
  name           String
  email          String?
  phone          String?
  company        String?
  notes          String?
  legalName      String?  @map("legal_name")
  cnpj           String?
  address        String?
  cityState      String?  @map("city_state")
  cep            String?
  signerName     String?  @map("signer_name")
  signerCpf      String?  @map("signer_cpf")
  signerEmail    String?  @map("signer_email")
  billingContact String?  @map("billing_contact")
  formToken      String?  @unique @map("form_token")
  ownerId        String   @map("owner_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  owner               User                 @relation(fields: [ownerId], references: [id])
  deals               Deal[]
  tasks               Task[]
  activities          Activity[]
  contractSubmissions ContractSubmission[]
  onboardingForm      OnboardingForm?

  @@index([ownerId])
  @@index([name])
  @@map("clients")
}

model ContractSubmission {
  id             String   @id @default(uuid())
  clientId       String   @map("client_id")
  legalName      String   @map("legal_name")
  cnpj           String
  address        String
  cityState      String   @map("city_state")
  cep            String
  signerName     String   @map("signer_name")
  signerCpf      String   @map("signer_cpf")
  signerEmail    String   @map("signer_email")
  billingContact String   @map("billing_contact")
  submittedAt    DateTime @default(now()) @map("submitted_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("contract_submissions")
}

model Stage {
  id        String    @id @default(uuid())
  key       String    @unique
  label     String
  color     String
  position  Int
  type      StageType @default(OPEN)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  deals Deal[]

  @@index([position])
  @@map("stages")
}

model Deal {
  id        String    @id @default(uuid())
  title     String
  value     Decimal?  @db.Decimal(12, 2)
  stageId   String    @map("stage_id")
  position  Int       @default(0)
  clientId  String    @map("client_id")
  ownerId   String    @map("owner_id")
  originId  String?   @map("origin_id")
  notes     String?
  closedAt  DateTime? @map("closed_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  stage      Stage       @relation(fields: [stageId], references: [id])
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner      User        @relation(fields: [ownerId], references: [id])
  origin     LeadOrigin? @relation(fields: [originId], references: [id])
  activities Activity[]

  @@index([ownerId])
  @@index([stageId])
  @@map("deals")
}

model LeadOrigin {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  deals Deal[]

  @@map("lead_origins")
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(PENDENTE)
  dueDate     DateTime?  @map("due_date")
  clientId    String?    @map("client_id")
  ownerId     String     @map("owner_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  owner  User    @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([dueDate])
  @@map("tasks")
}

model Activity {
  id        String   @id @default(uuid())
  type      String
  content   String
  clientId  String?  @map("client_id")
  dealId    String?  @map("deal_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  user   User    @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([dealId])
  @@map("activities")
}

model OnboardingForm {
  id             String               @id @default(uuid())
  clientId       String               @unique @map("client_id")
  token          String?              @unique
  niche          OnboardingNiche
  targetPlan     OnboardingTargetPlan @map("target_plan")
  driveFolderId  String?              @map("drive_folder_id")
  driveFolderUrl String?              @map("drive_folder_url")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  createdById    String               @map("created_by_id")

  client      Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User                   @relation(fields: [createdById], references: [id])
  submissions OnboardingSubmission[]

  @@map("onboarding_forms")
}

model OnboardingSubmission {
  id          String   @id @default(uuid())
  formId      String   @map("form_id")
  answers     Json
  uploads     Json
  submittedAt DateTime @default(now()) @map("submitted_at")

  form OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("onboarding_submissions")
}
